# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host:5432/biyo

# Auth
JWT_SECRET=your_super_secret_jwt_key_here

# Razorpay (Platform keys for Biyo subscriptions)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Biyo Subscription Plan
RAZORPAY_PLAN_ID=your_299_monthly_plan_id

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# File Storage
FILE_STORAGE_URL=https://your-s3-bucket.amazonaws.com
